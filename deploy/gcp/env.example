# Copy this file to deploy/gcp/env.sh and update values.
#
# Usage:
#   source deploy/gcp/env.sh
#   ./deploy/gcp/deploy_cloud_run.sh

export PROJECT_ID="your-gcp-project-id"
export REGION="us-central1"

# Cloud Run service and job names.
export BACKEND_SERVICE="portfolio-backend"
export FRONTEND_SERVICE="portfolio-frontend"
export MIGRATION_JOB="portfolio-migrate"
export SEED_JOB="portfolio-seed"
export RUN_SEED_DATA="true"

# Runtime service account (name only, without @project.iam.gserviceaccount.com).
export RUNTIME_SA_NAME="portfolio-runtime"

# Artifact Registry.
export AR_REPO="portfolio"
export IMAGE_TAG="v1"
export SKIP_IMAGE_BUILD="false"

# Cloud SQL PostgreSQL.
export DB_INSTANCE="portfolio-pg"
export DB_VERSION="POSTGRES_15"
export DB_TIER="db-f1-micro"
export DB_STORAGE_GB="20"
export DB_NAME="portfolio"
export DB_USER="portfolio_app"

# Keep this URL-safe (letters, numbers, dot, underscore, dash, tilde).
export DB_PASSWORD="change-me-safe"

# Secret Manager names.
export DB_URL_SECRET="portfolio-database-url"
export DB_URL_SYNC_SECRET="portfolio-database-url-sync"
export APP_SECRET_KEY_SECRET="portfolio-app-secret-key"
export APP_SECRET_KEY_VALUE="replace-with-random-secret"

# Cloud Storage bucket mounted in backend at /app/data/uploads.
export USE_GCS_MOUNT="true"
export UPLOADS_BUCKET="your-gcp-project-id-portfolio-uploads"
export UPLOADS_MOUNT_PATH="/app/data/uploads"

# Backend runtime tuning.
export ENABLE_ADMIN_API="false"
export BACKEND_CPU="1"
export BACKEND_MEMORY="1Gi"
export BACKEND_MIN_INSTANCES="0"
export BACKEND_MAX_INSTANCES="3"
export BACKEND_TIMEOUT_SECONDS="300"
export BACKEND_EXTRA_ENV_VARS=""

# Frontend runtime tuning.
export FRONTEND_CPU="1"
export FRONTEND_MEMORY="1Gi"
export FRONTEND_MIN_INSTANCES="0"
export FRONTEND_MAX_INSTANCES="3"
export FRONTEND_TIMEOUT_SECONDS="300"

# Leave empty to auto-wire to backend Cloud Run URL.
export FRONTEND_API_BASE_URL=""
export FRONTEND_PUBLIC_API_BASE_URL=""

# Optional; can include comma-separated /uploads/... paths.
export PORTFOLIO_SKY_IMAGES=""
export FRONTEND_EXTRA_ENV_VARS=""

# Optional custom domain mapping values.
export FRONTEND_DOMAIN="portfolio.example.com"
export BACKEND_DOMAIN="api.portfolio.example.com"
export ROOT_DOMAIN="example.com"
export DNS_ZONE="portfolio-zone"