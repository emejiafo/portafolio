# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=freelance_db

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/freelance_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/freelance_db
SECRET_KEY=your-secret-key-change-in-production
ADMIN_PASSWORD=admin123

# Environment
ENVIRONMENT=development
DEBUG=true

# File Storage
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE=10485760

# Frontend
API_BASE_URL=http://backend:8000

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Business Info
BUSINESS_NAME=Your Business Name
BUSINESS_RFC=XXXX000000XXX